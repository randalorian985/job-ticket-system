SA_PASSWORD=replace-with-strong-sql-password
JWT_ISSUER=JobTicketSystem
JWT_AUDIENCE=JobTicketSystem.Api
JWT_SIGNING_KEY=replace-with-at-least-32-bytes-of-random-secret

# Optional one-time bootstrap values. Do not enable TestBootstrap in
# docker-compose.prod.yml for normal production restarts.
APP_ADMIN_USERNAME=bootstrap.admin
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=replace-with-temporary-rotated-password
APP_ADMIN_FIRST_NAME=Bootstrap
APP_ADMIN_LAST_NAME=Admin
